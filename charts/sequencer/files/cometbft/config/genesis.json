{
  "app_hash": "",
  "app_state": {
    "nativeAssetBaseDenomination": "{{ .Values.genesis.nativeAssetBaseDenomination }}",
    "fees": {
      "transferBaseFee": {{ include "sequencer.fee" .Values.genesis.fees.transferBaseFee }},
      "sequenceBaseFee": {{ include "sequencer.fee" .Values.genesis.fees.sequenceBaseFee }},
      "sequenceByteCostMultiplier": {{ include "sequencer.fee" .Values.genesis.fees.sequenceByteCostMultiplier }},
      "initBridgeAccountBaseFee": {{ include "sequencer.fee" .Values.genesis.fees.initBridgeAccountBaseFee }},
      "bridgeLockByteCostMultiplier": {{ include "sequencer.fee" .Values.genesis.fees.bridgeLockByteCostMultiplier }},
      "bridgeSudoChangeFee": {{ include "sequencer.fee" .Values.genesis.fees.bridgeSudoChangeFee }},
      "ics20WithdrawalBaseFee": {{ include "sequencer.fee" .Values.genesis.fees.ics20WithdrawalBaseFee }}
    },
    "allowedFeeAssets": [
      {{- range $index, $value := .Values.genesis.allowedFeeAssets }}
      {{- if $index }},{{- end }}
      "{{ $value }}"
      {{- end }}
    ],
    "ibcParameters": {
      "ibcEnabled": {{ .Values.genesis.ibc.enabled }},
      "inboundIcs20TransfersEnabled": {{ .Values.genesis.ibc.inboundEnabled }},
      "outboundIcs20TransfersEnabled": {{ .Values.genesis.ibc.outboundEnabled }}
    },
    "addressPrefixes": {
      "base": "{{ .Values.genesis.addressPrefixes.base }}"
    },
    "accounts": [
      {{- range $index, $value := .Values.genesis.genesisAccounts }}
      {{- if $index }},{{- end }}
      {
        "address": {{ include "sequencer.address" $value.address }},
        "balance": {{ toString $value.balance | replace "\"" "" }}
      }
      {{- end }}
    ],
    "authoritySudoAddress": {{ include "sequencer.address" .Values.genesis.authoritySudoAddress }},
    "ibcSudoAddress": {{ include "sequencer.address" .Values.genesis.ibc.sudoAddress }},
    "ibcRelayerAddresses": [
      {{- range $index, $value := .Values.genesis.ibc.relayerAddresses }}
      {{- if $index }},{{- end }}
      {{ include "sequencer.address" $value }}
      {{- end }}
    ]
    {{- if not .Values.global.dev }}
    {{- else }}
    {{- end}}
  },
  "chain_id": "{{ .Values.genesis.chainId }}",
  "consensus_params": {
    "block": {
      "max_bytes": " {{ .Values.genesis.consensusParams.blockMaxBytes }}",
      "max_gas": "{{ .Values.genesis.consensusParams.blockMaxGas }}"
    },
    "evidence": {
      "max_age_duration": "{{ .Values.genesis.consensusParams.maxAgeDuration }}",
      "max_age_num_blocks": " {{ .Values.genesis.consensusParams.maxAgeNumBlocks }}",
      "max_bytes": "{{ .Values.genesis.consensusParams.maxBytes }}"
    },
    "validator": {
      "pub_key_types": [
        "ed25519"
      ]
    },
    "version": {
      "app": "0"
    }
  },
  "genesis_time": "{{ .Values.genesis.genesisTime }}",
  "initial_height": "0",
  "validators": [
  {{- range $index, $value := .Values.genesis.validators }}
      {{- if $index }},{{- end }}
      {
        "address": "{{ $value.address }}",
        "name": "{{ $value.name }}",
        "power": "{{ $value.power }}",
        "pub_key": {
          "type": "tendermint/PubKeyEd25519",
          "value": "{{ $value.pubKey }}"
        }
      }
  {{- end }}
  ]
}
